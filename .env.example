# Environment Configuration
# Copy this file to .env and update with your settings

# LLM Model (options: google/flan-t5-small, google/flan-t5-base, google/flan-t5-large)
LLM_MODEL=google/flan-t5-base

# Embeddings Model (options: all-MiniLM-L6-v2, all-mpnet-base-v2)
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# Chunking Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval Settings
DEFAULT_TOP_K=5

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit Settings
STREAMLIT_PORT=8501

# Optional: HuggingFace Token (for gated models)
# HUGGINGFACE_TOKEN=your_token_here
